# ── Development: monorepo root volume-mount ile hot-reload ──────────────────
# Build context: repo root (docker-compose.override.yml'de context: . olarak ayarlı)
FROM node

WORKDIR /app

# Copy everything to ensure all workspaces and package.json files are present for npm install
COPY . .

RUN npm install

WORKDIR /app/templates/api

EXPOSE 3001

# .env dosyası /app/.env konumunda, working dir templates/api olduğu için relative path kullan
CMD ["node", "--watch", "--experimental-strip-types", "--env-file=../../.env", "src/main.ts"]
