{
  "name": "@cms/template-api",
  "version": "1.0.0",
  "description": "Modular CMS API — Fastify shell template",
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "dev": "node --watch --env-file=../../.env src/main.ts",
    "dev:tsx": "tsx watch --env-file=../../.env src/main.ts",
    "type-check": "tsc --noEmit",
    "build": "tsc",
    "start": "node --env-file=../../.env src/main.ts",
    "seed": "node --env-file=../../.env src/scripts/seed.ts",
    "generate-test-data": "tsx --env-file=../../.env src/scripts/generate-test-submissions.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.712.0",
    "@cms/core": "*",
    "@cms/db": "*",
    "@fastify/cookie": "^11",
    "@fastify/cors": "^11",
    "@fastify/helmet": "^13",
    "@fastify/multipart": "^10",
    "@fastify/rate-limit": "^11",
    "@fastify/swagger": "^9",
    "@fastify/swagger-ui": "^6",
    "bcrypt": "^6",
    "fastify": "^5",
    "fastify-plugin": "^6.0.0",
    "jsonwebtoken": "^9",
    "pino": "^10",
    "zod": "^4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bcrypt": "^6",
    "@types/jsonwebtoken": "^9",
    "@types/node": "^26",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "pino-pretty": "^13",
    "typescript": "^6",
    "typescript-eslint": "^8.62.0"
  }
}
