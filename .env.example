# ── Port Configuration ────────────────────────────────────────────────────────
MONGO_PORT=27017
REDIS_PORT=6379
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
API_PORT=3001
ADMIN_PORT=3002
CLIENT_PORT=3003

# ── API ───────────────────────────────────────────────────────────────────────
NODE_ENV=production
JWT_SECRET=change_this_to_a_strong_random_secret
LOG_LEVEL=info
MONGO_DB_NAME=cms
MONGO_URI=mongodb://mongo:27017
REDIS_URL=redis://redis:6379

# ── Storage (S3 / MinIO) ──────────────────────────────────────────────────────
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=cms-backups
S3_REGION=us-east-1

# ── Admin Panel ───────────────────────────────────────────────────────────────
# NEXT_PUBLIC_API_URL is intentionally removed.
# Admin uses Next.js rewrites to proxy /api/* → API_PORT (server-side only).
# This prevents the internal API address from being exposed to the browser.

# ── Client (Public Site) ──────────────────────────────────────────────────────
INTERNAL_API_URL=http://api:3001
