COMPOSE_PROJECT_NAME=cms

# ── Port Configuration ────────────────────────────────────────────────────────
API_PORT=3001
ADMIN_PORT=3002
CLIENT_PORT=3003

# ── API ───────────────────────────────────────────────────────────────────────
NODE_ENV=production
JWT_SECRET=CHANGE_THIS_TO_A_STRONG_RANDOM_SECRET_AT_LEAST_32_CHARS_LONG
LOG_LEVEL=warn
MONGO_DB_NAME=cms_prod

# ── MongoDB Authentication ────────────────────────────────────────────────────
MONGO_ROOT_USERNAME=cms_admin
MONGO_ROOT_PASSWORD=CHANGE_THIS_TO_A_STRONG_PASSWORD
MONGO_URI=mongodb://cms_admin:CHANGE_THIS_TO_A_STRONG_PASSWORD@mongo:27017

# ── Redis Authentication ──────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_THIS_TO_A_STRONG_REDIS_PASSWORD
REDIS_URL=redis://:CHANGE_THIS_TO_A_STRONG_REDIS_PASSWORD@redis:6379

# ── Storage (S3 / MinIO) ──────────────────────────────────────────────────────
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=CHANGE_THIS_MINIO_ACCESS_KEY
S3_SECRET_KEY=CHANGE_THIS_MINIO_SECRET_KEY_TO_A_STRONG_VALUE
S3_BUCKET=cms-backups
S3_REGION=us-east-1

# ── MinIO Root Credentials ────────────────────────────────────────────────────
MINIO_ROOT_USER=CHANGE_THIS_MINIO_ACCESS_KEY
MINIO_ROOT_PASSWORD=CHANGE_THIS_MINIO_SECRET_KEY_TO_A_STRONG_VALUE

# ── CORS Configuration ────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for production
# Example: https://admin.example.com,https://example.com
ALLOWED_ORIGINS=https://admin.example.com,https://example.com

# ── Admin Panel ───────────────────────────────────────────────────────────────
# Admin uses Next.js rewrites to proxy /api/* → API_PORT (server-side only).
# This prevents the internal API address from being exposed to the browser.

# ── Client (Public Site) ──────────────────────────────────────────────────────
INTERNAL_API_URL=http://api:3001
